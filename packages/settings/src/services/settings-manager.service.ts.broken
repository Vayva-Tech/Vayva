  // ============================================================================
  // DATABASE OPERATIONS
  // ============================================================================

  /**
   * Load settings from database
   */
  private async loadFromDatabase(): Promise<void> {
    try {
      if (!this.dbConnection) return;

      const settings = await this.dbConnection.settings.findFirst({
        where: { active: true },
      });

      if (settings) {
        this.store = {
          ...this.store,
          ...settings.data,
        };
      }
    } catch (error) {
      console.error('[SETTINGS] Failed to load from database:', error);
    }
  }

  /**
   * Save settings to database
   */
  async saveToDatabase(): Promise<void> {
    try {
      if (!this.dbConnection) return;

      await this.dbConnection.settings.upsert({
        where: { id: 'default' },
        update: {
          data: this.store,
          updatedAt: new Date(),
        },
        create: {
          id: 'default',
          data: this.store,
          active: true,
        },
      });
    } catch (error) {
      console.error('[SETTINGS] Failed to save to database:', error);
      throw error;
    }
  }

  // ============================================================================
  // GETTER METHODS
  // ============================================================================

  /**
   * Get entire settings store
   */
  getAllSettings(): SettingsStore {
    return { ...this.store };
  }

  /**
   * Get specific section of settings
   */
  getSection<K extends keyof SettingsStore>(section: K): SettingsStore[K] {
    return this.store[section];
  }

  /**
   * Get nested value using dot notation path
   */
  getValue<T = any>(path: string): T | undefined {
    const keys = path.split('.');
    let value: any = this.store;

    for (const key of keys) {
      if (value === undefined || value === null) return undefined;
      value = value[key];
    }

    return value as T;
  }

  /**
   * Get business settings
   */
  getBusinessSettings(): BusinessSettings {
    return this.store.business;
  }

  /**
   * Get AI settings
   */
  getAISettings(): AISettings {
    return this.store.ai;
  }

  /**
   * Get dashboard settings
   */
  getDashboardSettings(): DashboardSettings {
    return this.store.dashboard;
  }

  /**
   * Get notification settings
   */
  getNotificationSettings(): NotificationSettings {
    return this.store.notifications;
  }

  /**
   * Get user preferences
   */
  getUserPreferences(): UserPreferences {
    return this.store.user;
  }

  /**
   * Get industry-specific settings
   */
  getIndustrySettings(industry: string): any {
    return this.store.industry[industry as keyof IndustrySettings];
  }

  // ============================================================================
  // SETTER METHODS
  // ============================================================================

  /**
   * Update entire section
   */
  async setSection<K extends keyof SettingsStore>(
    section: K,
    value: SettingsStore[K],
    options: { validate?: boolean; persist?: boolean; notify?: boolean } = {}
  ): Promise<void> {
    const { validate = true, persist = false, notify = true } = options;

    if (validate) {
      this.validateSection(section, value);
    }

    this.store[section] = value;

    if (notify) {
      this.notifyListeners(section, '', value);
    }

    if (persist) {
      await this.saveToDatabase();
    }
  }

  /**
   * Update nested value using dot notation path
   */
  async setValue<T = any>(
    path: string,
    value: T,
    options: { validate?: boolean; persist?: boolean; notify?: boolean } = {}
  ): Promise<void> {
    const { validate = true, persist = false, notify = true } = options;

    const keys = path.split('.');
    const lastKey = keys.pop()!;
    
    let current: any = this.store;
    for (const key of keys) {
      if (current[key] === undefined) {
        current[key] = {};
      }
      current = current[key];
    }

    current[lastKey] = value;

    if (notify) {
      const section = keys[0] as keyof SettingsStore;
      const relativePath = keys.slice(1).join('.') + '.' + lastKey;
      this.notifyListeners(section, relativePath, value);
    }

    if (persist) {
      await this.saveToDatabase();
    }
  }

  /**
   * Update business settings
   */
  async setBusinessSettings(settings: Partial<BusinessSettings>, persist = false): Promise<void> {
    this.store.business = {
      ...this.store.business,
      ...settings,
    };

    if (persist) {
      await this.saveToDatabase();
    }

    this.notifyListeners('business', '', this.store.business);
  }

  /**
   * Update AI settings
   */
  async setAISettings(settings: Partial<AISettings>, persist = false): Promise<void> {
    this.store.ai = {
      ...this.store.ai,
      ...settings,
    };

    if (persist) {
      await this.saveToDatabase();
    }

    this.notifyListeners('ai', '', this.store.ai);
  }

  /**
   * Update dashboard settings
   */
  async setDashboardSettings(settings: Partial<DashboardSettings>, persist = false): Promise<void> {
    this.store.dashboard = {
      ...this.store.dashboard,
      ...settings,
    };

    if (persist) {
      await this.saveToDatabase();
    }

    this.notifyListeners('dashboard', '', this.store.dashboard);
  }

  /**
   * Update industry settings
   */
  async setIndustrySettings(industry: string, settings: any, persist = false): Promise<void> {
    this.store.industry = {
      ...this.store.industry,
      [industry]: settings,
    };

    if (persist) {
      await this.saveToDatabase();
    }

    this.notifyListeners('industry', industry, settings);
  }

  // ============================================================================
  // VALIDATION
  // ============================================================================

  /**
   * Validate a settings section against its schema
   */
  validateSection(section: keyof SettingsStore, value: any): ValidationErrors[] {
    const errors: ValidationErrors[] = [];

    try {
      switch (section) {
        case 'business':
          businessSettingsSchema.parse(value);
          break;
        case 'industry':
          industrySettingsSchema.parse(value);
          break;
        case 'dashboard':
          dashboardSettingsSchema.parse(value);
          break;
        case 'ai':
          aiSettingsSchema.parse(value);
          break;
        case 'notifications':
          notificationSettingsSchema.parse(value);
          break;
        case 'user':
          userPreferencesSchema.parse(value);
          break;
      }
    } catch (error) {
      if (error instanceof z.ZodError) {
        error.errors.forEach((err) => {
          errors.push({
            section: section as string,
            field: err.path.join('.'),
            error: err.message,
          });
        });
      }
      throw new Error(`Settings validation failed: ${errors.map(e => `${e.field}: ${e.error}`).join(', ')}`);
    }

    return errors;
  }

  /**
   * Validate entire settings store
   */
  validateAll(): ValidationErrors[] {
    const errors: ValidationErrors[] = [];

    Object.keys(this.store).forEach((key) => {
      const sectionErrors = this.validateSection(key as keyof SettingsStore, this.store[key as keyof SettingsStore]);
      errors.push(...sectionErrors);
    });

    return errors;
  }

  // ============================================================================
  // EVENT LISTENERS
  // ============================================================================

  /**
   * Subscribe to settings changes
   */
  subscribe(section: keyof SettingsStore, handler: SettingsChangeHandler): () => void {
    if (!this.listeners.has(section)) {
      this.listeners.set(section, new Set());
    }

    const sectionListeners = this.listeners.get(section)!;
    sectionListeners.add(handler);

    // Return unsubscribe function
    return () => {
      sectionListeners.delete(handler);
    };
  }

  /**
   * Notify all listeners of a change
   */
  private notifyListeners(section: keyof SettingsStore, path: string, value: any): void {
    const sectionListeners = this.listeners.get(section);
    if (sectionListeners) {
      sectionListeners.forEach((handler) => {
        try {
          handler(section, path, value);
        } catch (error) {
          console.error('[SETTINGS] Error in settings listener:', error);
        }
      });
    }
  }

  // ============================================================================
  // UTILITY METHODS
  // ============================================================================

  /**
   * Reset settings to defaults
   */
  reset(section?: keyof SettingsStore): void {
    if (section) {
      this.store[section] = this.getDefaultSettings()[section];
      this.notifyListeners(section, '', this.store[section]);
    } else {
      this.store = this.getDefaultSettings();
      Object.keys(this.listeners).forEach((section) => {
        this.notifyListeners(section as keyof SettingsStore, '', this.store[section as keyof SettingsStore]);
      });
    }
  }

  /**
   * Export settings as JSON
   */
  exportSettings(): string {
    return JSON.stringify(this.store, null, 2);
  }

  /**
   * Import settings from JSON
   */
  async importSettings(json: string, persist = false): Promise<void> {
    try {
      const imported = JSON.parse(json);
      
      // Validate each section
      Object.keys(imported).forEach((key) => {
        this.validateSection(key as keyof SettingsStore, imported[key]);
      });

      this.store = {
        ...this.store,
        ...imported,
      };

      if (persist) {
        await this.saveToDatabase();
      }

      // Notify all sections
      Object.keys(imported).forEach((section) => {
        this.notifyListeners(section as keyof SettingsStore, '', imported[section]);
      });
    } catch (error) {
      throw new Error(`Failed to import settings: ${error}`);
    }
  }

  /**
   * Clear cache
   */
  clearCache(): void {
    this.cache.clear();
  }
}
