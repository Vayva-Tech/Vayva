import { z } from 'zod';
import { businessSettingsSchema, type BusinessSettings } from '../schemas/business-settings.schema.js';
import { industrySettingsSchema, type IndustrySettings } from '../schemas/industry-settings.schema.js';
import { dashboardSettingsSchema, type DashboardSettings } from '../schemas/dashboard-settings.schema.js';
import { aiSettingsSchema, type AISettings } from '../schemas/ai-settings.schema.js';
import { notificationSettingsSchema, type NotificationSettings } from '../schemas/notification-settings.schema.js';
import { userPreferencesSchema, type UserPreferences } from '../schemas/user-preferences.schema.js';

/**
 * Settings Manager Service
 * 
 * Centralized service for managing all application settings.
 * Handles storage, retrieval, validation, and synchronization.
 */

// ============================================================================
// TYPES & INTERFACES
// ============================================================================

export interface SettingsStore {
  business: BusinessSettings;
  industry: IndustrySettings;
  dashboard: DashboardSettings;
  ai: AISettings;
  notifications: NotificationSettings;
  user: UserPreferences;
}

export interface SettingsChangeHandler {
  (section: keyof SettingsStore, path: string, value: any): void;
}

export interface ValidationErrors {
  section: string;
  field: string;
  error: string;
}

export class SettingsManager {
  private store: SettingsStore;
  private listeners: Map<string, Set<SettingsChangeHandler>>;
  private dbConnection?: any; // Prisma client or other DB connection
  private cache: Map<string, { data: any; timestamp: number }>;
  private cacheExpirationMs: number = 60000; // 1 minute

  constructor() {
    this.store = this.getDefaultSettings();
    this.listeners = new Map();
    this.cache = new Map();
  }

  // ============================================================================
  // INITIALIZATION
  // ============================================================================

  /**
   * Initialize settings manager with database connection
   */
  async initialize(dbConnection?: any): Promise<void> {
    this.dbConnection = dbConnection;
    
    if (dbConnection) {
      await this.loadFromDatabase();
    }
  }

