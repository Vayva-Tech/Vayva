{
  "name": "@vayva/dashboard-engine",
  "version": "1.0.0",
  "description": "Dashboard engine that connects settings to actual dashboard behavior",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests configured\" && exit 0"
  },
  "dependencies": {
    "@vayva/settings": "workspace:*",
    "@vayva/industry-core": "workspace:*",
    "@vayva/industry-retail": "workspace:*",
    "@vayva/industry-restaurant": "workspace:*",
    "@vayva/industry-healthcare": "workspace:*",
    "@vayva/industry-legal": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.2.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}