{
  "name": "@vayva/industry-retail",
  "version": "0.1.0",
  "private": false,
  "description": "Vayva Retail Industry Engine - Omnichannel, store performance, transfers, customer segmentation",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./engine": "./src/retail.engine.ts",
    "./dashboard": "./src/dashboard-config.ts",
