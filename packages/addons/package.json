{
  "name": "@vayva/addons",
  "version": "1.0.0",
  "description": "Vayva Add-On System - Types, Registry, Components, and Mount Points",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.js"
    },
    "./registry": {
      "types": "./src/registry.ts",
      "import": "./dist/registry.mjs",
      "require": "./dist/registry.js"
    },
    "./mount-points": {
      "types": "./src/mount-points/index.ts",
      "import": "./dist/mount-points.mjs",
      "require": "./dist/mount-points.js"
    },
    "./storefront": {
      "types": "./src/components/storefront.tsx",
      "import": "./dist/components/storefront.mjs",
      "require": "./dist/components/storefront.js"
    },
    "./settings": {
      "types": "./src/components/settings.tsx",
      "import": "./dist/components/settings.mjs",
      "require": "./dist/components/settings.js"
    },
    "./shopping-cart": {
      "types": "./src/shopping-cart/index.tsx",
      "import": "./dist/shopping-cart/index.mjs",
      "require": "./dist/shopping-cart/index.js"
    },
    "./checkout-flow": {
      "types": "./src/checkout-flow/index.tsx",
      "import": "./dist/checkout-flow/index.mjs",
      "require": "./dist/checkout-flow/index.js"
    },
    "./product-pages": {
      "types": "./src/product-pages/index.tsx",
      "import": "./dist/product-pages/index.mjs",
      "require": "./dist/product-pages/index.js"
    },
    "./wishlist": {
      "types": "./src/wishlist/index.tsx",
      "import": "./dist/wishlist/index.mjs",
      "require": "./dist/wishlist/index.js"
    },
    "./reviews": {
      "types": "./src/reviews/index.tsx",
      "import": "./dist/reviews/index.mjs",
      "require": "./dist/reviews/index.js"
    },
    "./booking": {
      "types": "./src/booking/index.tsx",
      "import": "./dist/booking/index.mjs",
      "require": "./dist/booking/index.js"
    },
    "./newsletter": {
      "types": "./src/newsletter/index.tsx",
      "import": "./dist/newsletter/index.mjs",
      "require": "./dist/newsletter/index.js"
    },
    "./api": {
      "types": "./src/api/routes.ts",
      "import": "./dist/api/routes.mjs",
      "require": "./dist/api/routes.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@vayva/ui": "workspace:^",
    "date-fns": "^3.0.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "keywords": [
    "vayva",
    "addons",
    "plugins",
    "extensions",
    "ecommerce",
    "storefront",
    "react",
    "nextjs"
  ],
  "license": "MIT",
  "sideEffects": false
}
