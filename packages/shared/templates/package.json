    "clsx": "^2.1.1",
    "framer-motion": "^12.26.2",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.0.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
