{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "paths": {
            "bullmq": ["packages/shared/utils/node_modules/bullmq"],
            "bullmq/*": ["packages/shared/utils/node_modules/bullmq/*"],
            "ioredis": ["packages/shared/utils/node_modules/ioredis"],
            "ioredis/*": ["packages/shared/utils/node_modules/ioredis/*"]
        }
    },
    "include": ["src"],
    "exclude": [
        "node_modules",
        "src/__tests__",
        "src/logger-unified.ts"
    ]
}