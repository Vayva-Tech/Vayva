{
  "name": "@vayva/security",
  "version": "0.0.1",
  "description": "SAML SSO, fraud detection and security utilities for Vayva",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "lint": "eslint src/ --config ../../.eslintrc.json",
    "lint:fix": "eslint src/ --config ../../.eslintrc.json --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vayva/db": "workspace:*",
    "@vayva/shared": "workspace:*",
    "@node-saml/node-saml": "^4.0.5",
    "date-fns": "^4.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^22.15.21",
    "vitest": "^4.0.18"
  },
  "eslintConfig": {
    "rules": {
      "@typescript-eslint/no-unused-vars": [
        "warn",
        { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_|^TODO" }
      ],
      "@typescript-eslint/no-explicit-any": "warn",
      "no-console": ["warn", { "allow": ["warn", "error"] }]
    }
  }
}
