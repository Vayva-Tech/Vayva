{
  "extends": "../tsconfig/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/dashboard/**/*", "src/components/**/*", "src/widgets/**/*", "src/types/**/*"],
  "exclude": ["node_modules", "dist", "src/services", "src/food.engine.ts", "src/food-grocery.engine.ts"]
}
