enum DomainStatus {
  PENDING      // Awaiting DNS verification
  VERIFYING    // DNS verification in progress
  ACTIVE       // Domain is active and serving
  FAILED       // Verification failed
  SUSPENDED    // Domain suspended
  EXPIRED      // Domain/SSL expired
}

enum SSLType {
  AUTOMATIC    // Vercel/Vayva managed (Let's Encrypt)
  CUSTOM       // Merchant-provided certificate
  ADVANCED     // Advanced SSL with custom config
}

enum SSLStatus {
  PENDING      // Certificate pending
  ISSUING      // Certificate being issued
  ACTIVE       // Certificate active
  EXPIRING     // Certificate expiring soon
  EXPIRED      // Certificate expired
  FAILED       // Certificate issuance failed
  REVOKED      // Certificate revoked
}
