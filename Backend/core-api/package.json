{
    "name": "@vayva/merchant-api",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "playwright": "playwright",
        "dev": "sh -c 'next dev -p 3001'",
        "build": "next build --webpack",
        "start": "sh -c 'next start -p ${PORT:-3000}'",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --exclude='**/{groq-client,sales-agent,merchant-brain.service,DeliveryService,account,route}.test.ts'",
        "check:domain": "node scripts/check-domain.js",
        "migrate:domain": "node scripts/migrate-domain.js",
        "production:scan": "bash scripts/production-scan.sh",
        "preproduction:build": "npm run production:scan",
        "seo:snapshot": "node scripts/seo/snapshot.js",
        "seo:validate": "node scripts/seo/validate-manifest.js seo/manifest.json && node scripts/seo/validate-keywords.js seo/manifest.json && node scripts/seo/validate-sitemap.js public/sitemap.xml seo/manifest.json && node scripts/seo/validate-robots.js public/robots.txt",
        "test:chaos": "tsx ../../scripts/chaos-test.ts",
        "cleanup:dry-run": "tsx ../../scripts/cleanup-data.ts",
        "cleanup:exec": "tsx ../../scripts/cleanup-data.ts --exec"
    },
    "dependencies": {
