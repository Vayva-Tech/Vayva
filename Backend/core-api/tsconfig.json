{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "target": "es2017",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noImplicitAny": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@vayva/db": [
                "../../platform/infra/db/src/client.ts"
            ],
            "@vayva/payments": [
                "../../packages/domain/payments/src/index.ts"
            ],
            "@vayva/payments/*": [
                "../../packages/domain/payments/src/*"
            ],
            "@vayva/affiliate": [
                "../../packages/affiliate/src/index.ts"
            ],
            "@vayva/affiliate/*": [
                "../../packages/affiliate/src/*"
            ],
            "@vayva/compliance": [
                "../../packages/compliance/src/index.ts"
            ],
            "@vayva/templates": [
                "../../packages/shared/templates/src/index.ts"
            ],
            "@vayva/templates/*": [
                "../../packages/shared/templates/src/*"
            ],
            "@vayva/shared": [
                "../../packages/shared/src/index.ts"
            ],
            "@vayva/shared/*": [
                "../../packages/shared/src/*"
            ],
            "@vayva/ui": [
                "../../packages/ui/src/index.ts"
            ],
            "@vayva/ui/*": [
                "../../packages/ui/src/*"
            ],
            "@vayva/ai-agent": [
                "../../packages/ai-agent/src/index.ts"
            ],
            "@vayva/analytics": [
                "../../packages/domain/analytics/src/index.ts"
            ],
            "@vayva/analytics/*": [
                "../../packages/domain/analytics/src/*"
            ],
            "@vayva/redis": [
                "../../packages/infra/redis-adapter/src/index.ts"
            ],
            "@vayva/industry-core": [
                "../../packages/industry-core/src/index.ts"
            ],
            "@vayva/industry-core/*": [
                "../../packages/industry-core/src/*"
            ],
            "@vayva/security": [
                "../../packages/security/src/index.ts"
            ],
            "@vayva/security/*": [
                "../../packages/security/src/*"
            ],
            "@vayva/billing": [
                "../../packages/billing/src/index.ts"
            ],
            "@vayva/billing/*": [
                "../../packages/billing/src/*"
            ],
            "@vayva/integrations": [
                "../../packages/integrations/src/index.ts"
            ],
            "@vayva/integrations/*": [
                "../../packages/integrations/src/*"
            ],
            "@fashion-prisma": [
                "../../packages/industry-fashion/src/lib/prisma-fashion.ts"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        "src/types/**/*.ts",
        "src/types/**/*.d.ts"
    ],
    "exclude": [
        // src/app/api: only excluded subtrees with known drift; wallet, subscriptions, account, orders, etc. remain typechecked.
        "node_modules",
        ".next",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "src/services/paystack-webhook.ts",
        "src/services/wallet.ts",
        "src/context/WalletContext.tsx",
        "vitest.config.ts",
        "scripts",
        "src/app/api/ai/**",
        "src/app/api/beauty/**",
        "src/app/api/billing/**",
        "src/app/api/blog/**",
        "src/app/api/box-subscriptions/**",
        "src/app/api/compliance/**",
        "src/app/api/creative/**",
        "src/app/api/dashboard/**",
        "src/app/api/education/**",
        "src/app/api/events/**",
        "src/app/api/finance/**",
        "src/app/api/fashion/**",
        "src/app/api/grocery/**",
        "src/app/api/healthcare/**",
        "src/app/api/integrations/**",
        "src/app/api/inventory/**",
        "src/app/api/kitchen/**",
        "src/app/api/legal/**",
        "src/app/api/merchant/**",
        "src/app/api/nightlife/**",
        "src/app/api/nonprofit/**",
        "src/app/api/pos/**",
        "src/app/api/reports/**",
        "src/app/api/professional/**",
        "src/app/api/realestate/**",
        "src/app/api/rentals/**",
        "src/app/api/restaurant/**",
        "src/app/api/retail/**",
        "src/app/api/returns/**",
        "src/app/api/reviews/**",
        "src/app/api/saas/**",
        "src/app/api/security/**",
        "src/app/api/social-connections/**",
        "src/app/api/templates/**",
        "src/app/api/settlements/**",
        "src/app/api/services/**",
        "src/app/api/travel/**",
        "src/app/api/v1/**",
        "src/app/api/webhooks/**",
        "src/app/api/wellness/**",
        "src/app/api/wholesale/**"
    ]
}