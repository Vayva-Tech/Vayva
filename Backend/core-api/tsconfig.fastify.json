{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": false
  },
  "include": [
    "src/server-fastify.ts",
    "src/fastify-index.ts",
    "src/config/fastify.ts",
    "src/routes/**/*",
    "src/lib/logger.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/app/**/*",
    "src/components/**/*",
    "src/hooks/**/*",
    "src/styles/**/*"
  ]
}
