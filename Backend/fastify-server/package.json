{
  "name": "@vayva/fastify-server",
  "version": "1.0.0",
  "description": "Vayva Platform Fastify Backend API Server",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/swagger": "^8.15.0",
    "@fastify/type-provider-typebox": "^4.0.0",
    "@vayva/db": "workspace:*",
    "dotenv": "^16.4.5",
    "fastify": "^4.29.1",
    "pino": "^9.14.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.16",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.2"
  }
}
