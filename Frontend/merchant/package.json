{
    "name": "@vayva/merchant",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "playwright": "playwright",
        "test:e2e:smoke": "playwright test e2e/merchant-minimal-smoke.spec.ts",
        "test:e2e:route-stress": "playwright test e2e/merchant-route-stress.spec.ts",
        "generate:merchant-routes": "node scripts/generate-merchant-routes.mjs",
        "stress:routes:fetch": "node scripts/merchant-route-fetch-stress.mjs",
        "dev": "sh -c 'next dev -p ${PORT:-3000}'",
        "build": "next build --webpack",
        "start": "sh -c 'next start -p ${PORT:-3000}'",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --exclude='**/{groq-client,sales-agent,merchant-brain.service,DeliveryService,account,route}.test.ts'",
        "check:domain": "node scripts/check-domain.js",
        "migrate:domain": "node scripts/migrate-domain.js",
