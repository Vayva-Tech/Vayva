# Vayva Merchant Admin - Environment Variables

# Database
DATABASE_URL="postgresql://..."
REDIS_URL="redis://localhost:6379"

# Authentication & Security
JWT_SECRET="your-jwt-secret-here"
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Monitoring
SENTRY_DSN="https://key@sentry.io/project"

# Paystack (Test Keys)
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."

# Resend (Email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="onboarding@resend.dev"

#
# Storage
# Vayva uses MinIO / S3-compatible storage for uploads (not Cloudinary).
# Configure these in your deployment environment as needed.
#
# MINIO_ENDPOINT=""
# MINIO_ACCESS_KEY=""
# MINIO_SECRET_KEY=""
# MINIO_BUCKET=""
# MINIO_REGION="us-east-1"
# MINIO_PUBLIC_BASE_URL=""

# P11.2: Ops Dashboard Feature Flags (default: ON in dev, OFF in prod)
OPS_P11_2_ENABLED="true"
OPS_API_ERROR_TRACKING_ENABLED="true"
OPS_INTEGRATION_HEALTH_ENABLED="true"

# Feature Flags
ENABLE_AI_ASSISTANT="true"
LAUNCH_MODE="false"

# AI & LLM (OpenRouter)
OPENROUTER_API_KEY="sk-or-..."
AI_MODEL="google/gemini-2.5-flash"
AI_MAX_TOKENS="1024"
AI_TEMPERATURE="0.7"

# Delivery (Kwik)
KWIK_API_KEY="your-kwik-key"
KWIK_MERCHANT_ID="your-merchant-id"
KWIK_BASE_URL="https://api.kwik.delivery"
KWIK_WEBHOOK_SECRET="your-webhook-secret"

# WhatsApp Integration (Evolution API - self-hosted)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="your-evolution-api-key"

# Legacy / not used (Meta WhatsApp Cloud API)
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_VERIFY_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""

# Identity Verification
# Vayva uses manual KYC review (no YouVerify integration).

# File Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_STOREFRONT_URL="http://localhost:3001"
