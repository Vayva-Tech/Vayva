			<noscript><style>.lazyload[data-src]{display:none !important;}</style></noscript><style>.lazyload{background-image:none !important;}.lazyload:before{background-image:none !important;}</style><script>document.addEventListener("DOMContentLoaded", function() {
  // Select the WPML language menu item
  const wpmlItem = document.querySelector(".menu-item.wpml-ls-item");
  
  if (wpmlItem) {
    // Get the parent ul element containing the menu items
    const menu = wpmlItem.closest("ul");

    // Check if the wpmlItem is already the last child
    const lastItem = menu.lastElementChild;
    
    if (wpmlItem === lastItem) {
      // Move the WPML item to the second-to-last position
      menu.insertBefore(wpmlItem, lastItem.previousElementSibling);
    }
  }
});
