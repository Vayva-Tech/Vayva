{
  "expo": {
    "name": "Vayva",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/vayva-logo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/vayva-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.vayva.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vayva.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/vayva-logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-dev-client",
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "15e89878-bc5c-489a-9738-c0c94c3c20ba"
      }
    },
    "owner": "fred.vayva"
  }
}
