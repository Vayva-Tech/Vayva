# Vayva Storefront - Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Database (Optional if using Proxy)
DATABASE_URL="postgresql://..."

# Paystack
NEXT_PUBLIC_PAYSTACK_KEY="pk_test_..."

# Feature Flags
ENABLE_AI_ASSISTANT="true"
ENABLE_EMAIL_NOTIFICATIONS="true"

# Multi-Tenant Configuration
NEXT_PUBLIC_VAYVA_DOMAIN=vayva.ng
NEXT_PUBLIC_ENABLE_CUSTOM_DOMAINS=true

# Vercel (for custom domain automation)
# VERCEL_TOKEN=your_token
# VERCEL_PROJECT_ID=your_project_id
