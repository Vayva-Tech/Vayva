{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "**/.env.*",
        "**/tsconfig.json"
    ],
    "globalPassThroughEnv": [
        "NODE_ENV",
        "VERCEL",
        "VERCEL_ENV",
        "VERCEL_URL",
        "CI",
        "DATABASE_URL",
        "DIRECT_URL",
        "REDIS_URL",
        "NEXTAUTH_URL",
        "NEXTAUTH_SECRET",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "PAYSTACK_SECRET_KEY",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "EMAIL_HELLO",
        "EVOLUTION_API_URL",
        "EVOLUTION_API_KEY",
        "GROQ_ADMIN_KEY",
        "GROQ_MARKETING_KEY",
        "GROQ_WHATSAPP_KEY",
        "GROQ_API_KEY",
        "GROQ_API_KEY_RESCUE",
        "GROQ_API_KEY_MARKETING",
        "MINIO_ENDPOINT",
        "MINIO_ACCESS_KEY",
        "MINIO_SECRET_KEY",
        "MINIO_BUCKET",
        "MINIO_PUBLIC_BASE_URL",
        "INTERNAL_API_SECRET",
        "OPS_CONSOLE_URL",
        "OPS_OWNER_EMAIL",
        "OPS_OWNER_PASSWORD",
        "OPS_BOOTSTRAP_ENABLE",
        "OPS_RESCUE_ENABLE",
        "MERCHANT_ADMIN_URL",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_MARKETING_URL",
        "NEXT_PUBLIC_MARKETPLACE_URL",
        "NEXT_PUBLIC_STOREFRONT_URL",
        "NEXT_PUBLIC_OPS_URL",
        "NEXT_PUBLIC_PAYSTACK_KEY",
        "NEXT_PUBLIC_GROQ_API_KEY",
        "MARKETING_BASE_URL",
        "MARKETING_ORIGIN",
        "MERCHANT_ORIGIN",
        "OPS_ORIGIN",
        "PUBLIC_ASSETS_BASE_URL",
        "VAYVA_E2E_MODE"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**",
                "lib/**",
                "src/generated/**"
            ]
        },
        "lint": {},
        "typecheck": {
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": [
                "build"
            ],
            "outputs": [
                "coverage/**"
            ],
            "inputs": [
                "src/**/*.tsx",
                "src/**/*.ts",
                "test/**/*.ts",
                "test/**/*.tsx"
            ]
        },
        "db:generate": {
            "cache": true,
            "outputs": [
                "src/generated/**"
            ]
        },
        "db:push": {
            "cache": false
        }
    }
}