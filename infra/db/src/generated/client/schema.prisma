// ============================================
// SAAS SUITE MODELS
// ============================================

model SaaSPlan {
  id           String  @id @default(uuid())
  storeId      String
  name         String
  description  String? @db.Text
  planCode     String // Unique identifier like "starter", "pro", "enterprise"
  priceMonthly Decimal @db.Decimal(10, 2)
  priceYearly  Decimal @db.Decimal(10, 2)
  currency     String  @default("USD")
  trialDays    Int     @default(0)
  isPublic     Boolean @default(true)
  isDefault    Boolean @default(false)
  sortOrder    Int     @default(0)

  // Features included in this plan (JSON array of feature codes)
  includedFeatures Json?

  // Usage limits
  maxUsers     Int?
  maxProjects  Int?
  maxStorageGB Int?
  maxApiCalls  Int? // Monthly API call limit

  // Plan metadata
  highlightFeature String? // Feature to highlight on pricing page
  badge            String? // Badge like "Popular", "Best Value"

  status String @default("active") // active, archived, draft

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions SaaSSubscription[]

  @@unique([storeId, planCode])
  @@index([storeId, status])
  @@index([isPublic, status])
  @@map("saas_plans")
}

model SaaSTenant {
  id      String @id @default(uuid())
  storeId String

  // Tenant identification
  name        String
  tenantCode  String // Unique tenant identifier/slug
  description String? @db.Text

  // Contact & billing info
  billingEmail   String
  billingName    String?
  billingAddress Json?
  taxId          String?

  // Tenant status
  status       String  @default("active") // active, suspended, cancelled, pending
  statusReason String? // Reason for suspension/cancellation

  // Tenant configuration
  customDomain String?
  timezone     String  @default("UTC")
  locale       String  @default("en")

  // Settings and metadata
  settings Json? // Tenant-specific settings
  metadata Json? // Flexible metadata storage

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions SaaSSubscription[]
  apiKeys       SaaSApiKey[]
  usageMetrics  SaaSUsageMetric[]

  @@unique([storeId, tenantCode])
  @@unique([customDomain])
  @@index([storeId, status])
  @@index([billingEmail])
  @@map("saas_tenants")
}

model SaaSSubscription {
  id      String @id @default(uuid())
  storeId String

  // Relations
  tenantId String
  tenant   SaaSTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId   String
  plan     SaaSPlan   @relation(fields: [planId], references: [id])

  // Subscription details
  status       String @default("active") // active, trialing, past_due, cancelled, paused
  billingCycle String @default("monthly") // monthly, yearly

  // Pricing
  price    Decimal @db.Decimal(10, 2)
  currency String  @default("USD")

  // Trial
  isTrial     Boolean   @default(false)
  trialEndsAt DateTime?

  // Billing periods
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  // Cancellation
  cancelledAt        DateTime?
  cancellationReason String?

  // Payment
  paymentMethodId String?
  lastPaymentAt   DateTime?
  nextPaymentAt   DateTime?

  // Features & limits for this subscription (snapshot from plan + custom)
  customLimits   Json?
  customFeatures Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, status])
  @@index([tenantId, status])
  @@index([planId])
  @@index([nextPaymentAt])
  @@map("saas_subscriptions")
}

model SaaSFeatureFlag {
  id      String @id @default(uuid())
  storeId String

  // Feature identification
  name        String
  key         String // Unique feature key like "new_dashboard", "ai_assistant"
  description String? @db.Text

  // Feature type
  type String @default("boolean") // boolean, percentage, user_segment, plan_based

  // Targeting rules (JSON)
  // For boolean: { enabled: true/false }
  // For percentage: { enabled: true, percentage: 50 }
  // For user_segment: { enabled: true, segments: ["enterprise"] }
  // For plan_based: { enabled: true, plans: ["pro", "enterprise"] }
  targetingRules Json

  // Status
  isEnabled Boolean @default(false)

  // Evaluation context
  environment String @default("production") // development, staging, production

  // Scheduling
  startAt DateTime?
  endAt   DateTime?

  // Metadata
  createdBy String?
  updatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, key, environment])
  @@index([storeId, isEnabled])
  @@index([storeId, environment])
  @@map("saas_feature_flags")
}

model SaaSApiKey {
  id      String @id @default(uuid())
  storeId String

  // Relations
  tenantId String
  tenant   SaaSTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Key details
  name      String // Human-readable name
  keyPrefix String // First 8 chars of key for identification
  keyHash   String // Hashed full key (never store raw key)

  // Scopes/permissions (JSON array)
  scopes Json // ["read:users", "write:orders", "admin"]

  // Rate limiting
  rateLimitPerMinute Int? @default(60)
  rateLimitPerHour   Int? @default(1000)

  // Usage tracking
  lastUsedAt DateTime?
  usageCount Int       @default(0)

  // Status
  status String @default("active") // active, revoked, expired

  // Expiration
  expiresAt DateTime?

  // IP restrictions (JSON array of allowed IPs)
  allowedIps Json?

  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  revokedAt    DateTime?
  revokedBy    String?
  revokeReason String?

  @@index([storeId, status])
  @@index([tenantId, status])
  @@index([keyPrefix])
  @@map("saas_api_keys")
}

model SaaSUsageMetric {
  id      String @id @default(uuid())
  storeId String

  // Relations
  tenantId String
  tenant   SaaSTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Metric details
  metricType  String // api_calls, storage_gb, users, projects, bandwidth
  metricValue Decimal @db.Decimal(15, 4)

  // Time period
  periodStart DateTime
  periodEnd   DateTime
  periodType  String   @default("daily") // hourly, daily, monthly

  // Additional metadata
  metadata Json? // Context like endpoint, feature used, etc.

  createdAt DateTime @default(now())

  @@index([storeId, metricType, periodStart])
  @@index([tenantId, metricType, periodStart])
  @@index([periodType, periodStart])
  @@map("saas_usage_metrics")
}

