// ============================================================================
// BNPL (BUY NOW PAY LATER) MODELS
// ============================================================================

model BNPLAgreement {
  id                  String  @id @default(uuid())
  orderId             String  @unique
  customerId          String
  merchantId          String
  storeId             String
  provider            String // paystack, carbon, credpal
  providerAgreementId String? // External provider's agreement ID

  // Financial details
  totalAmount          Int // in kobo
  upfrontAmount        Int // in kobo
  installmentAmount    Int // in kobo
  numberOfInstallments Int    @default(3)
  installmentInterval  String @default("monthly") // weekly, biweekly, monthly

  // Status tracking
  status      BNPLStatus @default(PENDING)
  appliedAt   DateTime   @default(now())
  approvedAt  DateTime?
  completedAt DateTime?
  defaultedAt DateTime?

  // Metadata
  metadata      Json? // Provider-specific data
  failureReason String?

  // Relations
  order        Order             @relation(fields: [orderId], references: [id])
  installments BNPLInstallment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, status])
  @@index([customerId, status])
  @@index([merchantId, status])
  @@index([provider, status])
  @@map("bnpl_agreements")
}

model BNPLInstallment {
  id          String @id @default(uuid())
  agreementId String

  // Payment details
  amount            Int // in kobo
  installmentNumber Int
  dueDate           DateTime
  paidDate          DateTime?

  // Status
  status InstallmentStatus @default(PENDING)

  // Transaction reference
  transactionRef String?
  paymentMethod  String? // card, bank_transfer, wallet
  failureReason  String?

  // Relations
  agreement BNPLAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agreementId, installmentNumber])
  @@index([agreementId, status])
  @@index([dueDate, status])
  @@map("bnpl_installments")
}

enum BNPLStatus {
  PENDING
  APPROVED
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
  REJECTED
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
  FAILED
  WAIVED
}

model BNPLProviderConfig {
  id       String @id @default(uuid())
  storeId  String
  provider String // paystack, carbon, credpal

  // Provider settings
  isEnabled     Boolean @default(false)
  apiKey        String? // Encrypted
  apiSecret     String? // Encrypted
  webhookSecret String? // For webhook verification

  // Business rules
  minAmount           Int     @default(1000000) // ₦10,000 in kobo
  maxAmount           Int     @default(50000000) // ₦500,000 in kobo
  upfrontRate         Decimal @default(0.25) // 25% upfront
  defaultInstallments Int     @default(3)

  // Provider-specific config
  settings Json? // { merchantCode, partnerId, etc }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, provider])
  @@index([storeId, isEnabled])
  @@map("bnpl_provider_configs")
}
