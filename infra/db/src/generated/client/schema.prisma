  @@unique([storeId, name])
  @@index([storeId, updatedAt])
  @@map("template_project")
}

// ============================================
// REFERRAL & AFFILIATE SYSTEM
// ============================================

model ReferralProgram {
  id                String   @id @default(uuid())
  storeId           String   @unique
  isActive          Boolean  @default(false)
  name              String   @default("Refer a Friend")
  description       String?
  rewardType        String   @default("percentage") // percentage, fixed, credit
  rewardValue       Decimal  @default(10) // 10% or ₦1000
  referrerReward    Decimal  @default(10) // Reward for the person who referred
  referredReward    Decimal  @default(10) // Reward for new customer
  minimumOrder      Decimal  @default(0)
  maxRewardsPerUser Int      @default(0) // 0 = unlimited
  expirationDays    Int      @default(30) // Days until referral code expires
  terms             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  codes ReferralCode[]

  @@map("referral_programs")
}

model ReferralCode {
  id           String    @id @default(uuid())
  programId    String
  customerId   String
  code         String    @unique
  uniqueLink   String    @unique
  totalClicks  Int       @default(0)
  totalSignups Int       @default(0)
  totalOrders  Int       @default(0)
  totalRevenue Decimal   @default(0)
  totalRewards Decimal   @default(0)
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  program  ReferralProgram @relation(fields: [programId], references: [id])
  customer Customer        @relation(fields: [customerId], references: [id])

  @@index([programId, customerId])
  @@index([code])
  @@map("referral_codes")
}

model ReferralConversion {
  id             String    @id @default(uuid())
  referralCodeId String
  referrerId     String // Customer who referred
  referredId     String // New customer
  orderId        String?
  orderAmount    Decimal?
  referrerReward Decimal
  referredReward Decimal
  status         String    @default("pending") // pending, confirmed, paid, cancelled
  referrerPaidAt DateTime?
  referredPaidAt DateTime?
  createdAt      DateTime  @default(now())
  confirmedAt    DateTime?

  @@index([referralCodeId, status])
  @@index([referrerId])
  @@map("referral_conversions")
}

model ReferralPayout {
  id            String    @id @default(uuid())
  customerId    String
  storeId       String
  amount        Decimal
  conversions   String[] // Array of conversion IDs
  status        String    @default("pending") // pending, processing, paid, failed
  paymentMethod String // wallet, bank_transfer
  paymentRef    String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([customerId, status])
  @@map("referral_payouts")
}

// ============================================
// AFFILIATE SYSTEM (External Partners)
// ============================================

model Affiliate {
  id      String          @id @default(uuid())
  storeId String
  userId  String?         @unique // Links to auth user if registered
  email   String
  name    String
  phone   String?
  status  AffiliateStatus @default(PENDING)

  // Bank Details for Paystack payouts
  bankCode              String? // Paystack bank code (e.g., "057" for Zenith)
  bankName              String? // Bank name for display
  accountNumber         String? // Bank account number
  accountName           String? // Verified account name
  paystackRecipientCode String? // Paystack transfer recipient code

  // Commission settings
  commissionRate Decimal @default(10) // Percentage
  commissionType String  @default("percentage") // percentage, fixed
  minimumPayout  Decimal @default(5000) // Minimum amount to trigger payout (in kobo/cents)

  // Earnings tracking
  totalEarnings    Decimal @default(0)
  pendingEarnings  Decimal @default(0)
  paidEarnings     Decimal @default(0)
  totalReferrals   Int     @default(0)
  totalConversions Int     @default(0)

  // Tracking
  referralCode       String  @unique
  customReferralLink String?

  // KYC/Verification
  kycStatus        KycStatus @default(PENDING)
  kycSubmittedAt   DateTime?
  kycVerifiedAt    DateTime?
  verificationNote String?

  // Marketing preferences
  marketingConsent      Boolean @default(true)
  preferredPayoutMethod String  @default("bank_transfer") // bank_transfer, wallet

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referrals AffiliateReferral[]
  payouts   AffiliatePayout[]
  earnings  AffiliateEarning[]

  @@index([storeId, status])
  @@index([storeId, kycStatus])
  @@index([referralCode])
  @@map("affiliates")
}

model AffiliateReferral {
  id          String                  @id @default(uuid())
  affiliateId String
  customerId  String // The customer who was referred
  orderId     String?
  orderAmount Decimal?
  commission  Decimal
  status      AffiliateReferralStatus @default(PENDING)
  paidAt      DateTime?
  payoutId    String?

  // Tracking
  referralSource String? // Where the referral came from
  deviceType     String?
  utmCampaign    String?

  createdAt   DateTime  @default(now())
  convertedAt DateTime? // When the referral converted (made a purchase)

  affiliate Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId, status])
  @@index([customerId])
  @@map("affiliate_referrals")
}

model AffiliateEarning {
  id          String    @id @default(uuid())
  affiliateId String
  referralId  String?
  orderId     String?
  amount      Decimal
  type        String // commission, bonus, adjustment
  description String?
  status      String    @default("pending") // pending, paid, cancelled
  payoutId    String?
  createdAt   DateTime  @default(now())
  paidAt      DateTime?

  affiliate Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId, status])
  @@map("affiliate_earnings")
}

model AffiliatePayout {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  storeId     String
  amount      Decimal
  fee         Decimal   @default(0)
  netAmount   Decimal

  // Paystack transfer details
  paystackTransferCode String? // Paystack transfer reference
  paystackTransferId   String? // Paystack transfer ID
  bankName             String?
  accountNumber        String?

  status AffiliatePayoutStatus @default(PENDING)

  // Earnings included in this payout
  earningIds String[]

  // Processing tracking
  initiatedAt   DateTime  @default(now())
  processedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  // Approval workflow (for larger amounts)
  requiresApproval Boolean   @default(false)
  approvedBy       String?
  approvedAt       DateTime?

  // Webhook tracking
  webhookReceivedAt DateTime?
  webhookData       Json?

  @@index([affiliateId, status])
  @@index([storeId, status])
  @@index([paystackTransferCode])
  @@map("affiliate_payouts")
}

enum AffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
  INACTIVE
}

enum AffiliateReferralStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  REFUNDED
}

enum AffiliatePayoutStatus {
  PENDING
  APPROVAL_REQUIRED
  APPROVED
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

