// Phase 5: Settlement Batches for merchant payouts
model SettlementBatch {
  id             String           @id @default(uuid())
  storeId        String
  status         SettlementStatus @default(PENDING)
  periodStart    DateTime
  periodEnd      DateTime
  totalAmount    Decimal          @default(0) @db.Decimal(12, 2)
  totalOrders    Int              @default(0)
  totalFees      Decimal          @default(0) @db.Decimal(12, 2)
  totalRefunds   Decimal          @default(0) @db.Decimal(12, 2)
  netAmount      Decimal          @default(0) @db.Decimal(12, 2)
  transactionIds String[]         @default([])
  payoutId       String? // Reference to payout when processed
  processedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([storeId, periodEnd(sort: Desc)])
  @@map("settlement_batches")
}

// Phase 5: Stock Transfers between inventory locations
model StockTransfer {
  id             String         @id @default(uuid())
  storeId        String
  fromLocationId String
  toLocationId   String
  status         TransferStatus @default(PENDING)
  requestorId    String? // User who initiated
  approverId     String? // User who approved
  items          Json // Array of {variantId, quantity, notes}
  totalItems     Int            @default(0)
  notes          String?
  sentAt         DateTime?
  receivedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  store        Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fromLocation InventoryLocation @relation("SourceTransfers", fields: [fromLocationId], references: [id], onDelete: Cascade)
  toLocation   InventoryLocation @relation("DestinationTransfers", fields: [toLocationId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([storeId, createdAt(sort: Desc)])
  @@map("stock_transfers")
}

