model ProductVariant {
  id             String   @id @default(uuid())
  storeId        String
  productId      String
  sku            String?
  barcode        String?
  title          String
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  costPrice      Decimal? @db.Decimal(10, 2)
  inventory      Int      @default(0)
  weight         Decimal? @db.Decimal(10, 2)
  options        Json? // { size: "M", color: "Blue" }
  imageUrl       String?
  position       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product              Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems            CartItem[]
  inventoryItems       InventoryItem[]
  inventoryEvents      InventoryEvent[]
  inventoryAdjustments InventoryAdjustment[]
  orderItems           OrderItem[]

  @@index([productId])
  @@index([storeId, sku])
  @@map("product_variants")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  position  Int      @default(0)
  alt       String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
  @@map("product_images")
}

model PricingTier {
  id          String   @id @default(uuid())
  storeId     String
  productId   String
  tierName    String // e.g., "wholesale", "vip", "bulk"
  minQuantity Int      @default(1)
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, tierName])
  @@index([storeId])
  @@map("pricing_tiers")
}

model Refund {
  id                   String       @id @default(uuid())
  storeId              String
  orderId              String
  chargeId             String?
  paymentTransactionId String?
  approvalId           String?      @unique
  amount               Decimal      @db.Decimal(10, 2)
  currency             String       @default("NGN")
  reason               String?
  status               RefundStatus @default(REQUESTED)
  providerRefundId     String?
  processedAt          DateTime?
  failureCode          String?
  failureMessage       String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  store              Store               @relation(fields: [storeId], references: [id])
  order              Order               @relation(fields: [orderId], references: [id])
  charge             Charge?             @relation(fields: [chargeId], references: [id])
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id])
  approval           Approval?           @relation(fields: [approvalId], references: [id])

  @@index([storeId, status])
  @@index([orderId])
  @@map("refunds")
}

model Role {
  id          String   @id @default(uuid())
  storeId     String
  name        String
  key         String // e.g., "admin", "manager", "staff"
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  memberships     Membership[]

  @@unique([storeId, key])
  @@index([storeId])
  @@map("roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model SecuritySetting {
  id                String   @id @default(uuid())
  storeId           String   @unique
  twoFactorEnabled  Boolean  @default(false)
  twoFactorRequired Boolean  @default(false)
  ipWhitelist       String[] @default([])
  sessionTimeout    Int      @default(60) // minutes
  passwordMinLength Int      @default(8)
  requireStrongPass Boolean  @default(true)
  loginAttempts     Int      @default(5)
  lockoutDuration   Int      @default(30) // minutes
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("security_settings")
}

model RiskProfile {
  id               String   @id @default(uuid())
  storeId          String   @unique
  overallScore     Decimal  @default(50) // 0-100
  category         String   @default("medium") // low, medium, high
  factors          Json? // { chargebackRate: number, disputeRate: number, etc. }
  lastAssessmentAt DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("risk_profiles")
}

model Segment {
  id          String   @id @default(uuid())
  storeId     String
  name        String
  description String?
  criteria    Json // { conditions: [...], behaviors: [...] }
  customerIds String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, isActive])
  @@map("segments")
}

model MenuItem {
  id          String   @id @default(uuid())
  storeId     String
  name        String
  description String?
  category    String // appetizer, main, dessert, etc.
  price       Decimal  @db.Decimal(10, 2)
  cost        Decimal? @db.Decimal(10, 2) // Optional food cost
  imageUrl    String?
  isActive    Boolean  @default(true)
  prepTime    Int? // minutes
  allergens   String[] @default([])
  dietaryInfo String[] @default([]) // vegetarian, vegan, gluten-free
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipes        Recipe[]
  pricingHistory MenuItemPricing?

  @@index([storeId, category])
  @@index([storeId, isActive])
  @@map("menu_items")
}

// ============================================================================
// EDUCATION SUITE MODELS
// ============================================================================

enum CourseLevel {
  beginner
  intermediate
  advanced
}

enum LessonType {
  video
  text
  quiz
  assignment
}

enum EnrollmentStatus {
  active
  completed
  dropped
  suspended
}

enum QuestionType {
  multiple_choice
  true_false
  short_answer
}

model Course {
  id           String      @id @default(uuid())
  storeId      String
  title        String
  description  String      @db.Text
  thumbnailUrl String?
  instructorId String
  price        Decimal     @default(0)
  currency     String      @default("NGN")
  duration     Int         @default(0) // Total minutes
  level        CourseLevel @default(beginner)
  category     String
  tags         String[]    @default([])
  isPublished  Boolean     @default(false)
  publishedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  modules     CourseModule[]
  enrollments Enrollment[]

  @@index([storeId, isPublished])
  @@index([storeId, level])
  @@map("courses")
}

model CourseModule {
  id          String  @id @default(uuid())
  courseId    String
  title       String
  description String?
  orderIndex  Int     @default(0)
  isPublished Boolean @default(false)

  lessons Lesson[]

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, orderIndex])
  @@map("course_modules")
}

model Lesson {
  id          String     @id @default(uuid())
  moduleId    String
  title       String
  description String?
  type        LessonType @default(text)
  content     Json       @default("{}") // Video URL, text content, or quiz data
  duration    Int        @default(0) // minutes
  isPreview   Boolean    @default(false) // Free preview
  orderIndex  Int        @default(0)
  isPublished Boolean    @default(false)

  module   CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([moduleId, orderIndex])
  @@map("lessons")
}

model Enrollment {
  id             String           @id @default(uuid())
  courseId       String
  studentId      String
  status         EnrollmentStatus @default(active)
  progress       Decimal          @default(0) // 0-100
  startedAt      DateTime         @default(now())
  completedAt    DateTime?
  lastAccessedAt DateTime         @default(now())
  totalTimeSpent Int              @default(0) // minutes

  course       Course           @relation(fields: [courseId], references: [id])
  progressData LessonProgress[]
  certificate  Certificate?
  quizAttempts QuizAttempt[]

  @@unique([courseId, studentId])
  @@index([studentId, status])
  @@index([courseId, status])
  @@map("enrollments")
}

model LessonProgress {
  id           String    @id @default(uuid())
  enrollmentId String
  lessonId     String
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  timeSpent    Int       @default(0) // minutes
  lastPosition Decimal? // Video timestamp

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id])

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@map("lesson_progress")
}

model Quiz {
  id                 String  @id @default(uuid())
  lessonId           String  @unique
  title              String
  description        String?
  timeLimit          Int? // minutes, null = no limit
  passingScore       Int     @default(70) // percentage
  maxAttempts        Int     @default(3)
  shuffleQuestions   Boolean @default(true)
  showCorrectAnswers Boolean @default(true)

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String       @id @default(uuid())
  quizId        String
  question      String
  type          QuestionType @default(multiple_choice)
  options       Json? // For multiple choice: [{ text, isCorrect, id }]
  correctAnswer String? // For short answer or true_false
  explanation   String?
  points        Int          @default(1)
  orderIndex    Int          @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, orderIndex])
  @@map("quiz_questions")
}

model QuizAttempt {
  id            String    @id @default(uuid())
  quizId        String
  enrollmentId  String
  answers       Json      @default("{}") // { questionId: answer }
  score         Int       @default(0)
  maxScore      Int       @default(0)
  percentage    Int       @default(0)
  isPassed      Boolean   @default(false)
  startedAt     DateTime  @default(now())
  submittedAt   DateTime?
  timeSpent     Int       @default(0) // seconds
  attemptNumber Int       @default(1)

  quiz       Quiz       @relation(fields: [quizId], references: [id])
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@index([quizId, enrollmentId])
  @@index([enrollmentId])
  @@map("quiz_attempts")
}

model Certificate {
  id                String    @id @default(uuid())
  enrollmentId      String    @unique
  templateId        String
  certificateNumber String    @unique
  issuedAt          DateTime  @default(now())
  downloadUrl       String?
  verifiedAt        DateTime?
  verifiedBy        String?

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@index([certificateNumber])
  @@map("certificates")
}

model CertificateTemplate {
  id          String  @id @default(uuid())
  storeId     String
  name        String
  templateUrl String // SVG or HTML template
  fields      Json    @default("[]") // [{ name, x, y, fontSize, fontFamily }]
  isDefault   Boolean @default(false)

  @@index([storeId])
  @@map("certificate_templates")
}

