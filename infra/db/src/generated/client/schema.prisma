  @@unique([storeId, date])
  @@index([storeId, date])
  @@map("cash_flow_forecasts")
}

model InventoryForecast {
  id                 String   @id @default(uuid())
  storeId            String
  productId          String
  predictedDemand    Int
  stockoutRisk       Decimal // 0-1 probability
  suggestedReorder   Int
