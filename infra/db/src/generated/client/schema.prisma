// ============================================================================
// B2B WHOLESALE MODELS
// ============================================================================

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
  converted
}

enum CreditTransactionType {
  charge
  payment
  adjustment
  interest
}

enum RequisitionStatus {
  pending
  approved
  rejected
  ordered
}

enum RequisitionUrgency {
  low
  normal
  high
  urgent
}

model Quote {
  id                 String      @id @default(uuid())
  storeId            String
  customerId         String
  quoteNumber        String      @unique
  status             QuoteStatus @default(draft)
  expiryDate         DateTime
  subtotal           Decimal     @default(0)
  discount           Decimal     @default(0)
  tax                Decimal     @default(0)
  total              Decimal     @default(0)
  terms              String?
  notes              String?
  convertedToOrderId String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  items QuoteItem[]

  @@index([storeId, status])
  @@index([status, expiryDate])
  @@map("quotes")
}

model QuoteItem {
  id        String  @id @default(uuid())
  quoteId   String
  productId String
  quantity  Int     @default(1)
  unitPrice Decimal @default(0)
  discount  Decimal @default(0)
  total     Decimal @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

model CreditAccount {
  id              String   @id @default(uuid())
  storeId         String
  customerId      String   @unique
  creditLimit     Decimal
  currentBalance  Decimal  @default(0)
  availableCredit Decimal  @default(0)
  paymentTerms    String   @default("net_30") // net_30, net_60, net_90
  interestRate    Decimal  @default(0)
  isActive        Boolean  @default(true)
  approvedBy      String
  approvedAt      DateTime @default(now())

  transactions CreditTransaction[]

  @@index([storeId, isActive])
  @@map("credit_accounts")
}

model CreditTransaction {
  id           String                @id @default(uuid())
  accountId    String
  type         CreditTransactionType
  amount       Decimal
  balanceAfter Decimal
  referenceId  String? // Order ID or Payment ID
  description  String
  createdAt    DateTime              @default(now())
  createdBy    String

  account CreditAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
  @@index([type, createdAt])
  @@map("credit_transactions")
}

model Requisition {
  id             String             @id @default(uuid())
  storeId        String
  customerId     String
  requesterName  String
  requesterEmail String
  approverId     String?
  status         RequisitionStatus  @default(pending)
  urgency        RequisitionUrgency @default(normal)
  neededBy       DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  items RequisitionItem[]

  @@index([storeId, status])
  @@index([status, urgency])
  @@index([customerId, status])
  @@map("requisitions")
}

model RequisitionItem {
  id            String   @id @default(uuid())
  requisitionId String
  productId     String
  quantity      Int      @default(1)
  maxPrice      Decimal?
  notes         String?

  requisition Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
  @@map("requisition_items")
}

model CustomerHierarchy {
  id           String   @id @default(uuid())
  parentId     String // Parent customer (HQ)
  childId      String // Child customer (Branch)
  relationship String // subsidiary, franchise, branch
  createdAt    DateTime @default(now())

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
  @@map("customer_hierarchy")
}

model SalesForecast {
  id               String   @id @default(uuid())
  storeId          String
  period           DateTime
  periodType       String // 'daily', 'weekly', 'monthly'
  predictedRevenue Decimal
  confidence       Decimal
  upperBound       Decimal
  lowerBound       Decimal
  factors          Json // { seasonality: number, trend: number, events: string[] }
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([storeId, period, periodType])
  @@index([storeId, period])
  @@map("sales_forecasts")
}

model CashFlowForecast {
  id               String   @id @default(uuid())
  storeId          String
  date             DateTime
  predictedInflow  Decimal
  predictedOutflow Decimal
  netFlow          Decimal
  runwayDays       Int?
  alerts           Json // { lowBalance: boolean, shortfallRisk: number }
