  totalValue    Decimal  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([storeId, name])
  @@index([storeId])
  @@map("customer_segments")
}

model CustomerSegmentMembership {
  id         String   @id @default(uuid())
  customerId String
  segmentId  String
  score      Decimal // RFM score for this segment
  joinedAt   DateTime @default(now())

  @@unique([customerId, segmentId])
  @@index([segmentId])
  @@map("customer_segment_memberships")
}

model TemplateProject {
  id                       String                @id @default(cuid())
  storeId                  String?
  name                     String
  source                   TemplateProjectSource @default(NATIVE)
  basedOnSystemTemplateKey String?
  webstudioProjectId       String?
  thumbnailUrl             String?
  status                   TemplateProjectStatus @default(DRAFT)
  publishedDeploymentId    String?
  isGlobalDefault          Boolean               @default(false)
  config                   Json?                 @default("{}")
  lastPublishedAt          DateTime?
