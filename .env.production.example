# ============================================
# VAYVA PLATFORM - PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copy this file and fill in your actual values
# DO NOT commit the actual .env.production file to git
# ============================================

# --------------------------------------------
# DATABASE (Required for all apps)
# --------------------------------------------
# Get from: Neon.tech, Vercel Postgres, or Supabase
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/database?sslmode=require"

# --------------------------------------------
# NEXTAUTH (Required for all apps)
# --------------------------------------------
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here-min-32-characters"

# Canonical domains (recommended)
MARKETING_BASE_URL="https://vayva.ng"
MERCHANT_BASE_URL="https://merchant.vayva.ng"
OPS_BASE_URL="https://ops.vayva.ng"
STOREFRONT_ROOT_DOMAIN="vayva.ng"
STOREFRONT_PROTOCOL="https"
PUBLIC_ASSETS_BASE_URL="https://vayva.ng"

# App-specific URLs (legacy)
NEXTAUTH_URL="https://merchant.vayva.ng"
APP_URL="https://merchant.vayva.ng"
MARKETING_URL="https://vayva.ng"
OPS_URL="https://ops.vayva.ng"

# --------------------------------------------
# PAYSTACK (Payment Processing)
# --------------------------------------------
# Get from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY="sk_live_your_secret_key_here"
NEXT_PUBLIC_PAYSTACK_KEY="pk_live_your_public_key_here"
# Legacy alias (avoid if possible)
# PAYSTACK_PUBLIC_KEY="pk_live_your_public_key_here"

# --------------------------------------------
# RESEND (Email Service)
# --------------------------------------------
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"

# --------------------------------------------
# OPENROUTER AI (AI Features)
# --------------------------------------------
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-your_api_key_here"

# --------------------------------------------
# WHATSAPP (Evolution API - self-hosted)
# --------------------------------------------
EVOLUTION_API_URL="http://your-vps-ip:8080"
EVOLUTION_API_KEY="your-evolution-api-key"

# Legacy / not used (Meta WhatsApp Cloud API)
# META_ACCESS_TOKEN=""
# META_PHONE_NUMBER_ID=""
# META_VERIFY_TOKEN=""
# META_APP_SECRET=""
# META_WEBHOOK_URL=""

# --------------------------------------------
# KWIK DELIVERY (Optional - Delivery Integration)
# --------------------------------------------
# Get from: Kwik Delivery dashboard
KWIK_API_KEY="your_kwik_api_key"
KWIK_WEBHOOK_SECRET="your_kwik_webhook_secret"

# --------------------------------------------
# SENTRY (Optional - Error Tracking)
# --------------------------------------------
# Get from: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN="https://your_sentry_dsn@sentry.io/project_id"
SENTRY_AUTH_TOKEN="your_sentry_auth_token"

# --------------------------------------------
# ENVIRONMENT
# --------------------------------------------
NODE_ENV="production"
