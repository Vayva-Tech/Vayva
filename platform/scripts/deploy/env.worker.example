# ============================================
# VAYVA WORKER — ENV TEMPLATE
# ============================================
#
# Copy this file to /opt/vayva/worker.env on the App Server.
# systemd service reads this file via EnvironmentFile.
#
# Never commit real secrets.
#
# ============================================
# CRITICAL: EVOLUTION API KEY MUST MATCH
# ============================================
# This EVOLUTION_API_KEY must match AUTHENTICATION_API_KEY in ~/vayva/.env
# on the app server. If they don't match, WhatsApp messages will fail.
#

NODE_ENV=production

# ---- Database (VPS 2) ----
DATABASE_URL=postgresql://vayva:CHANGE_ME_DB_PASSWORD@db-server:5432/vayva

# ---- Redis (local docker compose on VPS 1) ----
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379
# Backward-compatible vars for legacy workers:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---- MinIO Object Storage (local docker compose on VPS 1) ----
MINIO_ENDPOINT=https://storage.vayva.ng
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET=vayva-uploads
MINIO_PUBLIC_BASE_URL=https://storage.vayva.ng
MINIO_REGION=us-east-1

# ---- Email (Resend) ----
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
EMAIL_FROM=no-reply@vayva.ng
EMAIL_PROVIDER=resend

# ---- AI (Groq) ----
GROQ_API_KEY=CHANGE_ME_GROQ_API_KEY
# Optional split keys used in some app contexts:
GROQ_API_KEY_RESCUE=
GROQ_API_KEY_MARKETING=

# ============================================
# WHATSAPP GATEWAY (Evolution API)
# ============================================
# CRITICAL: EVOLUTION_API_KEY must match AUTHENTICATION_API_KEY in app server's .env
# The Evolution API runs in Docker on localhost:8080
#
EVOLUTION_API_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=CHANGE_ME_EVOLUTION_API_KEY
EVOLUTION_INSTANCE_NAME=vayva-main

# ---- Payments / Internal APIs ----
PAYSTACK_SECRET_KEY=CHANGE_ME_PAYSTACK_SECRET_KEY
INTERNAL_API_SECRET=CHANGE_ME_INTERNAL_API_SECRET

# ---- App URLs ----
NEXT_PUBLIC_APP_URL=https://merchant.vayva.ng
VAYVA_DOMAIN=vayva.ng

# ---- Worker Flags ----
WORKER_ENABLE_MAINTENANCE_CLEANUP=true
WORKER_RUNNER=loop
OUTBOX_DRAIN_INTERVAL_SEC=30
