  storeId        String
  title          String
  description    String          @db.Text
  type           PropertyType
  purpose        PropertyPurpose
  price          Decimal
  currency       String          @default("NGN")
  address        String
  city           String
  state          String
  zipCode        String?
  lat            Decimal?
  lng            Decimal?
