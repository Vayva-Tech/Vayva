  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId, type])
  @@map("property_documents")
}

// ============================================================================
// B2B WHOLESALE MODELS
// ============================================================================

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
  converted
}

enum CreditTransactionType {
  charge
  payment
  adjustment
  interest
}

enum RequisitionStatus {
  pending
  approved
  rejected
  ordered
}

enum RequisitionUrgency {
  low
  normal
  high
  urgent
}

model Quote {
  id                 String      @id @default(uuid())
  storeId            String
  customerId         String
  quoteNumber        String      @unique
  status             QuoteStatus @default(draft)
  expiryDate         DateTime
  subtotal           Decimal     @default(0)
  discount           Decimal     @default(0)
  tax                Decimal     @default(0)
  total              Decimal     @default(0)
  terms              String?
  notes              String?
  convertedToOrderId String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  items QuoteItem[]

  @@index([storeId, status])
  @@index([status, expiryDate])
  @@map("quotes")
}

model QuoteItem {
  id        String  @id @default(uuid())
  quoteId   String
  productId String
  quantity  Int     @default(1)
  unitPrice Decimal @default(0)
  discount  Decimal @default(0)
  total     Decimal @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

model CreditAccount {
  id              String   @id @default(uuid())
  storeId         String
  customerId      String   @unique
  creditLimit     Decimal
  currentBalance  Decimal  @default(0)
  availableCredit Decimal  @default(0)
  paymentTerms    String   @default("net_30") // net_30, net_60, net_90
  interestRate    Decimal  @default(0)
  isActive        Boolean  @default(true)
  approvedBy      String
  approvedAt      DateTime @default(now())

  transactions CreditTransaction[]

  @@index([storeId, isActive])
  @@map("credit_accounts")
}

model CreditTransaction {
  id           String                @id @default(uuid())
  accountId    String
  type         CreditTransactionType
  amount       Decimal
  balanceAfter Decimal
  referenceId  String? // Order ID or Payment ID
  description  String
  createdAt    DateTime              @default(now())
  createdBy    String

  account CreditAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
  @@index([type, createdAt])
  @@map("credit_transactions")
}

model Requisition {
  id             String             @id @default(uuid())
  storeId        String
  customerId     String
  requesterName  String
  requesterEmail String
  approverId     String?
  status         RequisitionStatus  @default(pending)
  urgency        RequisitionUrgency @default(normal)
  neededBy       DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  items RequisitionItem[]

  @@index([storeId, status])
  @@index([status, urgency])
  @@index([customerId, status])
  @@map("requisitions")
}

model RequisitionItem {
  id            String   @id @default(uuid())
  requisitionId String
  productId     String
  quantity      Int      @default(1)
  maxPrice      Decimal?
  notes         String?

  requisition Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
  @@map("requisition_items")
}

model CustomerHierarchy {
  id           String   @id @default(uuid())
  parentId     String // Parent customer (HQ)
  childId      String // Child customer (Branch)
  relationship String // subsidiary, franchise, branch
  createdAt    DateTime @default(now())

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
  @@map("customer_hierarchy")
}

model SalesForecast {
  id               String   @id @default(uuid())
  storeId          String
  period           DateTime
  periodType       String // 'daily', 'weekly', 'monthly'
  predictedRevenue Decimal
  confidence       Decimal
  upperBound       Decimal
  lowerBound       Decimal
  factors          Json // { seasonality: number, trend: number, events: string[] }
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([storeId, period, periodType])
  @@index([storeId, period])
  @@map("sales_forecasts")
}

model CashFlowForecast {
  id               String   @id @default(uuid())
  storeId          String
  date             DateTime
  predictedInflow  Decimal
  predictedOutflow Decimal
  netFlow          Decimal
  runwayDays       Int?
  alerts           Json // { lowBalance: boolean, shortfallRisk: number }
  createdAt        DateTime @default(now())

  @@unique([storeId, date])
  @@index([storeId, date])
  @@map("cash_flow_forecasts")
}

model InventoryForecast {
  id                 String   @id @default(uuid())
  storeId            String
  productId          String
  predictedDemand    Int
  stockoutRisk       Decimal // 0-1 probability
  suggestedReorder   Int
  optimalReorderDate DateTime
  confidence         Decimal
  createdAt          DateTime @default(now())

  @@unique([storeId, productId])
  @@index([storeId, productId])
  @@map("inventory_forecasts")
}

model CustomerSegment {
  id            String   @id @default(uuid())
  storeId       String
  name          String
  description   String?
  criteria      Json // { rfm: { recency: number, frequency: number, monetary: number }, behaviors: string[] }
  color         String // Hex color for UI
  icon          String // Icon name
  customerCount Int      @default(0)
  totalValue    Decimal  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([storeId, name])
  @@index([storeId])
  @@map("customer_segments")
}

model CustomerSegmentMembership {
  id         String   @id @default(uuid())
  customerId String
  segmentId  String
  score      Decimal // RFM score for this segment
  joinedAt   DateTime @default(now())

  @@unique([customerId, segmentId])
  @@index([segmentId])
  @@map("customer_segment_memberships")
}

model TemplateProject {
  id                       String                @id @default(cuid())
  storeId                  String?
  name                     String
  source                   TemplateProjectSource @default(NATIVE)
  basedOnSystemTemplateKey String?
  webstudioProjectId       String?
  thumbnailUrl             String?
  status                   TemplateProjectStatus @default(DRAFT)
  publishedDeploymentId    String?
  isGlobalDefault          Boolean               @default(false)
  config                   Json?                 @default("{}")
  lastPublishedAt          DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  store       Store?            @relation("StoreTemplates", fields: [storeId], references: [id])
  deployments StoreDeployment[]

  @@unique([storeId, name])
  @@index([storeId, updatedAt])
  @@map("template_project")
}

// ============================================
// REFERRAL & AFFILIATE SYSTEM
// ============================================

model ReferralProgram {
  id                String   @id @default(uuid())
  storeId           String   @unique
  isActive          Boolean  @default(false)
  name              String   @default("Refer a Friend")
  description       String?
  rewardType        String   @default("percentage") // percentage, fixed, credit
  rewardValue       Decimal  @default(10) // 10% or ₦1000
  referrerReward    Decimal  @default(10) // Reward for the person who referred
  referredReward    Decimal  @default(10) // Reward for new customer
  minimumOrder      Decimal  @default(0)
  maxRewardsPerUser Int      @default(0) // 0 = unlimited
  expirationDays    Int      @default(30) // Days until referral code expires
  terms             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("referral_programs")
}

model ReferralCode {
  id           String    @id @default(uuid())
  programId    String
  customerId   String
  code         String    @unique
  uniqueLink   String    @unique
  totalClicks  Int       @default(0)
  totalSignups Int       @default(0)
  totalOrders  Int       @default(0)
  totalRevenue Decimal   @default(0)
  totalRewards Decimal   @default(0)
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([programId, customerId])
  @@index([code])
  @@map("referral_codes")
}

model ReferralConversion {
  id             String    @id @default(uuid())
  referralCodeId String
  referrerId     String // Customer who referred
  referredId     String // New customer
  orderId        String?
  orderAmount    Decimal?
  referrerReward Decimal
  referredReward Decimal
  status         String    @default("pending") // pending, confirmed, paid, cancelled
  referrerPaidAt DateTime?
  referredPaidAt DateTime?
  createdAt      DateTime  @default(now())
  confirmedAt    DateTime?

  @@index([referralCodeId, status])
  @@index([referrerId])
  @@map("referral_conversions")
}

model ReferralPayout {
  id            String    @id @default(uuid())
  customerId    String
  storeId       String
  amount        Decimal
  conversions   String[] // Array of conversion IDs
  status        String    @default("pending") // pending, processing, paid, failed
  paymentMethod String // wallet, bank_transfer
  paymentRef    String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([customerId, status])
  @@map("referral_payouts")
}

// ============================================
// WHATSAPP BROADCAST PRO
// ============================================

model WhatsAppBroadcast {
  id              String    @id @default(uuid())
  storeId         String
  name            String
  segmentId       String? // Target customer segment
  templateId      String?
  content         String
  mediaUrl        String?
  status          String    @default("draft") // draft, scheduled, sending, sent, failed
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int       @default(0)
  sentCount       Int       @default(0)
  failedCount     Int       @default(0)
  openCount       Int       @default(0)
  clickCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  createdBy       String

  @@index([storeId, status])
  @@map("whatsapp_broadcasts")
}

model WhatsAppTemplate {
  id              String   @id @default(uuid())
  storeId         String
  name            String
  category        String // marketing, transactional, utility
  content         String
  variables       String[] // Variable names like [customer_name], [order_id]
  mediaUrl        String?
  isApproved      Boolean  @default(false)
  approvalStatus  String   @default("pending") // pending, approved, rejected
  rejectionReason String?
  usageCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId, category])
  @@map("whatsapp_templates")
}

model WhatsAppBroadcastRecipient {
  id           String    @id @default(uuid())
  broadcastId  String
  customerId   String
  phoneNumber  String
  status       String    @default("pending") // pending, sent, delivered, read, failed
  errorCode    String?
  errorMessage String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?

  @@unique([broadcastId, customerId])
  @@index([broadcastId, status])
  @@map("whatsapp_broadcast_recipients")
}

// ============================================
// VIRTUAL TRY-ON (Fashion/Beauty)
// ============================================

model VirtualTryOnAsset {
  id            String   @id @default(uuid())
  storeId       String
  productId     String
  type          String // makeup, eyewear, clothing, jewelry
  assetUrl      String // 3D model or overlay image
  thumbnailUrl  String
  position      Json // { x, y, scale, rotation } for overlay positioning
  colorVariants Json // [{ color: "#FF0000", assetUrl: "..." }]
  isActive      Boolean  @default(true)
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([productId, type])
  @@index([storeId, type])
  @@map("virtual_try_on_assets")
}

model TryOnSession {
  id         String   @id @default(uuid())
  customerId String?
  sessionId  String   @unique // Browser session
  productId  String
  assetType  String
  snapshots  String[] // URLs to captured images
  shared     Boolean  @default(false)
  purchased  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([productId, createdAt])
  @@map("try_on_sessions")
}

// ============================================================================
// Operational Excellence Tools - Implementation Plan 2
// ============================================================================

// Recipe Cost Calculator Models (Food Industry)
model Ingredient {
  id            String   @id @default(uuid())
  storeId       String
  name          String
  unit          String // kg, g, l, ml, piece, etc.
  costPerUnit   Decimal
  supplier      String?
  stockQty      Decimal  @default(0)
  minStock      Decimal  @default(0)
  category      String // produce, protein, pantry, dairy, etc.
  shelfLifeDays Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recipes RecipeIngredient[]

  @@index([storeId, category])
  @@index([storeId, isActive])
  @@map("ingredients")
}

model Recipe {
  id           String   @id @default(uuid())
  storeId      String
  name         String
  description  String?
  menuItemId   String? // Link to menu item if applicable
  portions     Int      @default(1)
  prepTime     Int // minutes
  cookTime     Int // minutes
  instructions Json // Step-by-step
  imageUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ingredients RecipeIngredient[]
  costHistory RecipeCostHistory[]
  menuItem    MenuItem?           @relation(fields: [menuItemId], references: [id])

  @@index([storeId, menuItemId])
  @@index([storeId, isActive])
  @@map("recipes")
}

model RecipeIngredient {
  id           String  @id @default(uuid())
  recipeId     String
  ingredientId String
  quantity     Decimal // Amount needed for recipe portions
  isOptional   Boolean @default(false)

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
  @@index([recipeId])
  @@index([ingredientId])
  @@map("recipe_ingredients")
}

model RecipeCostHistory {
  id              String   @id @default(uuid())
  recipeId        String
  calculatedAt    DateTime @default(now())
  totalCost       Decimal
  costPerPortion  Decimal
  ingredientCosts Json // { ingredientId: { name, qty, costPerUnit, total } }

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, calculatedAt])
  @@map("recipe_cost_history")
}

model MenuItemPricing {
  id               String   @id @default(uuid())
  menuItemId       String   @unique
  recipeId         String?
  targetFoodCost   Decimal  @default(30) // percentage
  currentCost      Decimal
  suggestedPrice   Decimal
  actualPrice      Decimal
  grossMargin      Decimal
  profitPerPortion Decimal
  lastUpdated      DateTime @updatedAt

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([menuItemId])
  @@map("menu_item_pricing")
}

// Route Optimizer Models (Mobile Services)
model RoutePlan {
  id                String          @id @default(uuid())
  storeId           String
  name              String
  date              DateTime
  status            RoutePlanStatus @default(PLANNED)
  stops             RouteStop[]
  totalDistance     Decimal         @default(0) // km
  estimatedDuration Int             @default(0) // minutes
  actualDuration    Int?
  fuelCost          Decimal?
  assignedVehicleId String?
  assignedDriverId  String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  assignedVehicle Vehicle? @relation(fields: [assignedVehicleId], references: [id])

  @@index([storeId, date])
  @@index([storeId, status])
  @@map("route_plans")
}

model RouteStop {
  id               String          @id @default(uuid())
  routeId          String
  orderId          String?
  bookingId        String?
  customerId       String?
  address          String
  lat              Decimal?
  lng              Decimal?
  stopNumber       Int
  estimatedArrival DateTime
  actualArrival    DateTime?
  serviceDuration  Int             @default(30) // minutes
  windowStart      DateTime? // Time window constraint
  windowEnd        DateTime?
  status           RouteStopStatus @default(PENDING)
  notes            String?

  route RoutePlan @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId, stopNumber])
  @@index([routeId, status])
  @@map("route_stops")
}

model Vehicle {
  id             String      @id @default(uuid())
  storeId        String
  name           String
  type           VehicleType @default(CAR)
  licensePlate   String
  fuelEfficiency Decimal? // km per liter
  capacity       Int? // number of deliveries/persons
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  routes RoutePlan[]

  @@index([storeId, isActive])
  @@map("vehicles")
}

enum RoutePlanStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RouteStopStatus {
  PENDING
  ARRIVED
  COMPLETED
  SKIPPED
  DELAYED
}

enum VehicleType {
  CAR
  VAN
  BIKE
  TRUCK
}

// Digital Receipt System
model DigitalReceipt {
  id                String    @id @default(uuid())
  orderId           String    @unique
  storeId           String
  customerId        String
  receiptNumber     String
  qrCodeUrl         String?
  receiptUrl        String
  emailSent         Boolean   @default(false)
  whatsappSent      Boolean   @default(false)
  smsSent           Boolean   @default(false)
  emailOpenedAt     DateTime?
  feedbackSubmitted Boolean   @default(false)
  feedbackRating    Int? // 1-5
  reorderClicked    Boolean   @default(false)
  createdAt         DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([storeId, createdAt])
  @@index([customerId])
  @@map("digital_receipts")
}

// Wholesale Industry Models
model WholesaleOrder {
  id              String    @id @default(cuid())
  storeId         String
  customerId      String
  orderNumber     String    @unique
  status          String    @default("pending")
  totalAmount     Decimal   @db.Decimal(10, 4)
  currency        String    @default("NGN")
  items           Json      @default("[]")
  shippingAddress Json?
  billingAddress  Json?
  paymentStatus   String    @default("pending")
  paymentMethod   String?
  notes           String?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deliveredAt     DateTime?
  cancelledAt     DateTime?

  customer WholesaleCustomer @relation(fields: [customerId], references: [id])

  @@index([storeId, createdAt])
  @@index([customerId])
  @@index([status])
  @@map("wholesale_orders")
}

model WholesaleCustomer {
  id                 String   @id @default(cuid())
  storeId            String
  email              String
  phone              String?
  companyName        String?
  contactPerson      String?
  taxId              String?
  creditLimit        Decimal? @db.Decimal(10, 4)
  outstandingBalance Decimal  @default("0") @db.Decimal(10, 4)
  status             String   @default("active")
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orders WholesaleOrder[]

  @@index([storeId])
  @@index([email])
  @@map("wholesale_customers")
}
