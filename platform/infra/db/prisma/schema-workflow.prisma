// Workflow Models Extension
// Add these models to your main schema.prisma file

model Workflow {
  id          String           @id @default(cuid())
  name        String
  description String?
  industry    String
  merchantId  String
  merchant    Merchant         @relation(fields: [merchantId], references: [id])
  trigger     Json             // WorkflowTrigger
  nodes       Json             // WorkflowNode[]
  edges       Json             // WorkflowEdge[]
  status      WorkflowStatus   @default(draft)
  version     Int              @default(1)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdBy   String
  
  executions  WorkflowExecution[]
  
  @@index([merchantId])
  @@index([industry])
  @@index([status])
  @@index([merchantId, status])
  @@map("workflows")
}

model WorkflowExecution {
  id          String                @id @default(cuid())
  workflowId  String
  workflow    Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  merchantId  String
  status      ExecutionStatus       @default(pending)
  triggerData Json
  startedAt   DateTime              @default(now())
  completedAt DateTime?
  error       String?
  results     Json                  // WorkflowExecutionResult[]
  
  logs        WorkflowExecutionLog[]
  
  @@index([workflowId])
  @@index([merchantId])
  @@index([status])
  @@index([startedAt])
  @@index([workflowId, startedAt])
  @@map("workflow_executions")
}

model WorkflowExecutionLog {
  id          String              @id @default(cuid())
  executionId String
  execution   WorkflowExecution   @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeId      String
  nodeType    String
  status      LogStatus           @default(success)
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime            @default(now())
  completedAt DateTime?
  
  @@index([executionId])
  @@index([nodeId])
  @@index([executionId, nodeId])
  @@map("workflow_execution_logs")
}

enum WorkflowStatus {
  draft
  active
  paused
  archived
}

enum ExecutionStatus {
  pending
  running
  completed
  failed
  cancelled
}

enum LogStatus {
  success
  failed
  skipped
}
