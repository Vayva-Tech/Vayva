{
  "name": "vayva",
  "private": true,
  "packageManager": "pnpm@10.2.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency=30",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "node platform/ci/run-typecheck.mjs",
    "test": "turbo run test",
    "test:affected": "turbo run test typecheck --filter=...[origin/main] --continue --output-logs=errors-only",
    "test:smoke": "node platform/scripts/smoke.js",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "doctor": "node platform/scripts/doctor.js",
    "test:e2e": "playwright test --config=platform/testing/playwright.config.ts --pass-with-no-tests",
    "test:e2e:smoke:merchant": "pnpm --filter @vayva/merchant run test:e2e:smoke",
    "test:ui": "playwright test --ui --config=platform/testing/playwright.config.ts",
    "validate:ship": "pnpm doctor && pnpm lint && pnpm build && pnpm test:e2e",
    "ci:guards": "node platform/scripts/ci/check-hardcoded-domains.js && node platform/scripts/ci/check-merchant-auth-wrapper.js && node platform/scripts/ci/check-frontend-merchant-bff-auth.js && node platform/scripts/ci/check-merchant-idors.js && node platform/scripts/ci/check-merchant-placeholder-endpoints.js && node platform/scripts/ci/check-ops-auditlog.js && node platform/scripts/ci/check-docs-links.js && node platform/scripts/ci/check-docs-secrets.js",
    "check:security": "pnpm audit --audit-level=high",
    "check:runtime": "node platform/scripts/check-runtime-boundaries.mjs",
    "check:bundle": "node platform/scripts/check-bundle-size.mjs",
    "check:dead-code": "knip --no-exit-code",
    "check:a11y": "node scripts/verify-accessibility.js",
    "validate:accessibility": "pnpm check:a11y",
    "db:seed": "node platform/infra/db/prisma/seed.ts",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "postinstall": "turbo run db:generate"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@playwright/test": "^1.57.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.7",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jscodeshift": "^17.3.0",
    "jsonwebtoken": "^9.0.3",
    "knip": "^5.38.0",
    "prettier": "^3.8.0",
    "prisma": "5.7.0",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.7.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "schema": "platform/infra/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.9.1",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.28",
      "@types/react-dom": "18.3.7",
      "ioredis": "5.9.1",
      "tar": "7.5.4",
      "esbuild": "0.25.0",
      "lodash": "4.17.23"
    }
  }
}