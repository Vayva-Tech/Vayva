{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**/*.tsx",
        "app/**/*.ts",
        "components/**/*.tsx",
        "components/**/*.ts",
        "lib/**/*.ts"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "outputs": [],
      "inputs": [
        "app/**/*.tsx",
        "app/**/*.ts",
        "components/**/*.tsx", 
        "components/**/*.ts",
        "lib/**/*.ts"
      ]
    }
  }
}